<Window x:Class="ScriptReloader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Script Reloader - Docker over SSH"
        Height="560"
        Width="960"
        MinHeight="400"
        MinWidth="640">
    <DockPanel Margin="12">
        <DockPanel DockPanel.Dock="Bottom" LastChildFill="True" Margin="0,4,0,0">
            <TextBlock DockPanel.Dock="Right"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       FontSize="11"
                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                       Text="Authored by Kevyn Watkins" />
            <StatusBar Background="Transparent">
                <StatusBarItem>
                    <TextBlock x:Name="StatusText" Text="Disconnected." />
                </StatusBarItem>
            </StatusBar>
        </DockPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="SSH connection" Padding="8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="Host" VerticalAlignment="Center" />
                <TextBox x:Name="HostBox" Grid.Row="0" Grid.Column="1" Margin="4,2" VerticalContentAlignment="Center" />

                <Label Grid.Row="0" Grid.Column="2" Content="Port" VerticalAlignment="Center" Margin="8,0,0,0" />
                <TextBox x:Name="PortBox" Grid.Row="0" Grid.Column="3" Margin="4,2" VerticalContentAlignment="Center" />

                <StackPanel Grid.Row="0" Grid.Column="4" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                    <Button x:Name="ConnectButton" Content="Connect" Width="88" Margin="0,0,8,0" Click="ConnectButton_OnClick" />
                    <Button x:Name="DisconnectButton" Content="Disconnect" Width="88" IsEnabled="False" Click="DisconnectButton_OnClick" />
                </StackPanel>

                <Label Grid.Row="1" Grid.Column="0" Content="User" VerticalAlignment="Center" Margin="0,6,0,0" />
                <TextBox x:Name="UserBox" Grid.Row="1" Grid.Column="1" Margin="4,6,4,2" VerticalContentAlignment="Center" />

                <Label Grid.Row="1" Grid.Column="2" Content="Password" VerticalAlignment="Center" Margin="8,6,0,0" />
                <PasswordBox x:Name="PasswordBox" Grid.Row="1" Grid.Column="3" Grid.ColumnSpan="2" Margin="4,6,12,2" VerticalContentAlignment="Center" />

                <CheckBox x:Name="RememberConnectionCheckBox"
                          Grid.Row="2"
                          Grid.Column="0"
                          Grid.ColumnSpan="5"
                          Margin="0,8,0,0"
                          Content="Remember host, port, user, and password for this Windows user (stored under LocalAppData, password encrypted with DPAPI)"
                          Unchecked="RememberConnectionCheckBox_OnUnchecked" />
            </Grid>
        </GroupBox>

        <DataGrid x:Name="ContainersGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Extended"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  Margin="0,0,0,8">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="*" MinWidth="120" />
                <DataGridTextColumn Header="State" Binding="{Binding State}" Width="100" />
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="2*" MinWidth="160" />
                <DataGridTextColumn Header="Image" Binding="{Binding Image}" Width="2*" MinWidth="140" />
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="140" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="RefreshButton" Content="Refresh" Width="100" Margin="0,0,8,0" IsEnabled="False" Click="RefreshButton_OnClick" />
            <Button x:Name="RestartAllRunningButton"
                    Content="Restart all running"
                    Width="140"
                    Margin="0,0,8,0"
                    IsEnabled="False"
                    Click="RestartAllRunningButton_OnClick" />
            <Button x:Name="StopButton" Content="Stop selected" Width="110" Margin="0,0,8,0" IsEnabled="False" Click="StopButton_OnClick" />
            <Button x:Name="StartButton" Content="Start selected" Width="110" Margin="0,0,8,0" IsEnabled="False" Click="StartButton_OnClick" />
            <Button x:Name="RestartButton" Content="Restart selected" Width="120" IsEnabled="False" Click="RestartButton_OnClick" />
        </StackPanel>
        </Grid>
    </DockPanel>
</Window>
